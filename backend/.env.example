NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/doctorhub
SKIP_DATABASE_CONNECTION=false
JWT_ACCESS_SECRET=replace-with-256-bit-secret
JWT_REFRESH_SECRET=replace-with-256-bit-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
SUPABASE_URL=https://example.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# --- Optional Feature Flags ---
# Cloudinary (Used for image uploads)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# AI Configuration
# AI_PROVIDER=anthropic
# Get your API key from https://console.anthropic.com/
# ANTHROPIC_API_KEY=

# WebRTC (Video Calls)
# TURN server for WebRTC (optional - for video calls)
# TURN_URL=
# TURN_USERNAME=
# TURN_PASSWORD=
